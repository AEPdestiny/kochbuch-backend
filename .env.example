# Required for production database access.
# In local dev, Quarkus Dev Services can start PostgreSQL automatically when Docker is running.
DB_URL=jdbc:postgresql://localhost:5432/dishly
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Required in production. Use a long random value with at least 32 characters.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ISSUER=dishly-smart
JWT_EXPIRES_IN_SECONDS=3600

# Required in production so the backend accepts browser requests from the frontend.
CORS_ORIGINS=http://localhost:5173

# Optional: external recipe search/detail data.
# SPOONACULAR_API_KEYS accepts comma-separated keys for rotation; SPOONACULAR_API_KEY is the single-key fallback.
SPOONACULAR_API_KEYS=your_spoonacular_api_key
SPOONACULAR_API_KEY=your_spoonacular_api_key

# Optional: instruction search and restaurant web search.
TAVILY_API_KEY=your_tavily_api_key

# Optional: restaurant geocoding/search enrichment.
GEOAPIFY_API_KEY=your_geoapify_api_key

# Optional: recipe image upload via Supabase Storage.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=recipe-images

# Optional: Dishly AI / Groq. The frontend keeps Dishly AI disabled unless VITE_DISHLY_AI_ENABLED=true.
GROQ_API_KEY=optional_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
